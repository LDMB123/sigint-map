# Apple APIs Configuration
# Copy this file to .env and fill in your credentials

# =============================================================================
# APPLE DEVELOPER TEAM ID (Required for all Apple APIs)
# =============================================================================
# Find at: https://developer.apple.com/account → Membership → Team ID
APPLE_TEAM_ID=your_team_id_here

# =============================================================================
# APPLE MAPS SERVER API
# =============================================================================
# 1. Go to: https://developer.apple.com/account/resources/identifiers
# 2. Click + → Maps IDs → Register
# 3. Go to: https://developer.apple.com/account/resources/authkeys
# 4. Create a key with MapKit JS enabled
# 5. Download the .p8 file

APPLE_MAPS_KEY_ID=your_maps_key_id
# Either the path to your .p8 file OR the key contents directly:
APPLE_MAPS_PRIVATE_KEY=./AuthKey_XXXXXXXXXX.p8

# =============================================================================
# APPLE WEATHERKIT
# =============================================================================
# 1. Go to: https://developer.apple.com/account/resources/identifiers
# 2. Click + → Services IDs → Register (enable WeatherKit)
# 3. Go to: https://developer.apple.com/account/resources/authkeys
# 4. Create a key with WeatherKit enabled
# 5. Download the .p8 file

APPLE_WEATHER_KEY_ID=your_weather_key_id
APPLE_WEATHER_PRIVATE_KEY=./AuthKey_XXXXXXXXXX.p8

# =============================================================================
# APPLE MUSIC API
# =============================================================================
# 1. Go to: https://developer.apple.com/account/resources/identifiers
# 2. Click + → Services IDs → Register (enable MusicKit)
# 3. Go to: https://developer.apple.com/account/resources/authkeys
# 4. Create a key with MusicKit enabled
# 5. Download the .p8 file

APPLE_MUSIC_KEY_ID=your_music_key_id
APPLE_MUSIC_PRIVATE_KEY=./AuthKey_XXXXXXXXXX.p8
APPLE_MUSIC_SERVICE_ID=your_service_id

# =============================================================================
# NOTE: You can use the SAME private key for all services if you enable
# all capabilities (MapKit JS, WeatherKit, MusicKit) on a single key!
# =============================================================================
