#!/bin/bash
# Git pre-commit hook to prevent disorganization
# Automatically installed in .git/hooks/pre-commit

set -e

# Run organization enforcement
./.claude/scripts/enforce-organization.sh

EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
    echo ""
    echo "═══════════════════════════════════════════════════════"
    echo "  ⚠️  COMMIT BLOCKED: Organization issues detected"
    echo "═══════════════════════════════════════════════════════"
    echo ""
    echo "Please fix the organizational issues above before committing."
    echo ""
    echo "To bypass this check (not recommended):"
    echo "  git commit --no-verify"
    echo ""
    exit 1
fi

exit 0
