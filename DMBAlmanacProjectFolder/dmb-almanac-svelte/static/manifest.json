{
  "id": "/dmb-almanac",
  "name": "DMB Almanac - Dave Matthews Band Concert Database",
  "short_name": "DMB Almanac",
  "description": "The comprehensive database of Dave Matthews Band concert history, setlists, songs, venues, and statistics since 1991.",
  "start_url": "/?source=pwa",
  "scope": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui"],
  "title_bar_color": "#030712",
  "orientation": "portrait-primary",
  "theme_color": "#030712",
  "background_color": "#030712",
  "categories": ["entertainment", "music", "reference"],
  "dir": "ltr",
  "lang": "en-US",
