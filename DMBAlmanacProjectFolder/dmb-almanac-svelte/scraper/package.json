{
  "name": "dmb-almanac-scraper",
  "version": "1.0.0",
  "description": "Scraper for DMBAlmanac.com data",
  "type": "module",
  "scripts": {
    "scrape": "tsx src/orchestrator.ts",
    "scrape:all": "tsx src/orchestrator.ts all",
    "scrape:incremental": "tsx src/orchestrator.ts all --incremental",
    "scrape:legacy": "tsx src/index.ts",
    "scrape:venues": "tsx src/scrapers/venues.ts",
    "scrape:songs": "tsx src/scrapers/songs.ts",
    "scrape:song-stats": "tsx src/scrapers/song-stats.ts",
    "scrape:guests": "tsx src/scrapers/guests.ts",
    "scrape:shows": "tsx src/scrapers/shows.ts",
    "scrape:releases": "tsx src/scrapers/releases.ts",
    "scrape:tours": "tsx src/scrapers/tours.ts",
    "scrape:discography": "tsx src/scrapers/discography.ts",
    "scrape:liberation": "tsx src/scrapers/liberation.ts",
    "scrape:lists": "tsx src/scrapers/lists.ts",
    "scrape:history": "tsx src/scrapers/history.ts",
    "scrape:rarity": "tsx src/scrapers/rarity.ts",
    "scrape:venue-stats": "tsx src/scrapers/venue-stats.ts",
    "test": "tsx src/test-scraper.ts",
    "test:releases": "tsx src/test-releases-scraper.ts",
