{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Bash(npm install)",
      "Bash(npm install *)",
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(env)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(defaults write *)",
      "Bash(echo $*API_KEY*)",
      "Bash(export *API_KEY*)"
    ],
    "default": "ask"
  },
  "allowUnsandboxedCommands": false,
  "alwaysApproveWriteOperations": false
}
