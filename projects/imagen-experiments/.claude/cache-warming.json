{
  "description": "Cache warming configuration for Imagen Experiments token optimization",
  "version": "1.0.0",
  "priority_files": [
    "CLAUDE.md",
    "docs/KNOWLEDGE_BASE.md",
    "docs/EXPERIMENTS_INDEX.md",
    "docs/SESSION-MASTER-2026-02-02.md",
    "docs/QUICK-REFERENCE-SESSION-START.md",
    "package.json"
  ],
  "compressed_indexes": [
    {
      "index": "docs/KNOWLEDGE_BASE.md",
      "sources": [
        "docs/FIRST-PRINCIPLES-PHYSICS-METHODOLOGY.md",
        "docs/BOUNDARY-FINDINGS-REPORT.md",
        "docs/PHYSICS-CAPABILITY-MATRIX.md"
      ],
      "compression_ratio": 0.25,
      "token_savings": 60000
    },
    {
      "index": "docs/EXPERIMENTS_INDEX.md",
      "source": "docs/phase1-experiment-set-a.md",
      "compression_ratio": 0.10,
      "token_savings": 28000
    }
  ],
  "cache_on_startup": true,
  "refresh_interval": "session",
  "exclusions": [
    "node_modules/**",
    "dist/**",
    ".git/**",
    "output/**",
    "docs/_archived/**",
    "assets/**"
  ],
  "token_budget": {
    "target_per_session": 75000,
    "warning_threshold": 180000,
    "max_threshold": 220000
  }
}
