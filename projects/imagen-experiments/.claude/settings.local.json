{
  "permissions": {
    "allow": [
      "Read", "Write", "Edit", "Glob", "Grep",
      "Bash(node:*)",
      "Bash(node scripts/*)",
      "Bash(npm install)",
      "Bash(npm install *)",
      "Bash(npm run *)",
      "Bash(git status)", "Bash(git status *)", "Bash(git log *)", "Bash(git diff *)",
      "Bash(git add:*)", "Bash(git commit:*)",
      "Bash(ls)", "Bash(ls *)", "Bash(wc *)", "Bash(head *)"
    ],
    "deny": [
      "Bash(rm -rf *)", "Bash(sudo *)",
      "Bash(echo $*API_KEY*)", "Bash(echo $*SECRET*)",
      "Bash(export *API_KEY*)", "Bash(export *SECRET*)",
      "Bash(cat *KEY*)", "Bash(cat *SECRET*)"
    ],
    "default": "ask"
  },
  "allowUnsandboxedCommands": false,
  "alwaysApproveWriteOperations": false
}
