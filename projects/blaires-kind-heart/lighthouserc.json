{
  "ci": {
    "collect": {
      "staticDistDir": "./dist",
      "url": [
        "http://127.0.0.1:4173/",
        "http://127.0.0.1:4173/offline.html"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop",
        "throttlingMethod": "simulate",
        "maxWaitForLoad": 120000,
        "chromeFlags": "--headless=new --no-sandbox --disable-dev-shm-usage --disable-gpu"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": [
          "warn",
          {
            "minScore": 0.7
          }
        ],
        "largest-contentful-paint": [
          "warn",
          {
            "maxNumericValue": 5000
          }
        ],
        "cumulative-layout-shift": [
          "warn",
          {
            "maxNumericValue": 0.1
          }
        ],
        "total-blocking-time": [
          "warn",
          {
            "maxNumericValue": 600
          }
        ],
        "service-worker": "error",
        "installable-manifest": "error",
        "viewport": "error",
        "content-width": "error",
        "errors-in-console": "warn",
        "uses-http2": "off",
        "is-on-https": "off",
        "redirects-http": "off"
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": "./artifacts/lighthouse"
    }
  }
}
