# --- App ---
APP_ENV=development
LOG_LEVEL=INFO
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
# Required in production; use a deploy-specific identifier such as a git SHA.
RELEASE_SHA=dev
# Frontend/browser monitoring DSN. Leave blank to disable client-side Sentry.
NEXT_PUBLIC_SENTRY_DSN=
PORT=8000

# --- Database ---
# Default is ./gdl_data.db next to api_server.py
DB_PATH=./gdl_data.db

# --- Web security / CORS ---
# Use '*' for local dev. In production, set a comma-separated list, e.g.
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=*

# Optional in development. Required in production.
# TRUSTED_HOSTS=yourdomain.com,www.yourdomain.com
TRUSTED_HOSTS=

# Shared bearer token for protected POST admin APIs in production.
# If unset in production, refresh/sync/scrape stay disabled and the app serves
# read-only public GET endpoints only.
# If set in production, use a long random value (24+ chars).
ADMIN_API_TOKEN=

# --- Scraping ---
GDL_URL=https://www.greendotlabs.com/find-our-products/
HTTP_TIMEOUT_SECONDS=30

# --- GDL detail-page enrichment ---
# Supplements the main directory page with local dispensary detail pages so
# current flower drops are captured even when the top-level page is truncated.
DETAIL_PAGE_ENRICHMENT_ENABLED=true
DETAIL_PAGE_FETCH_LIMIT=16
DETAIL_PAGE_CONCURRENCY=4

# --- Scheduler ---
# Scheduler runs periodic menu scrapes. Safe with DB locks even across processes.
SCHEDULER_ENABLED=false
SCHEDULER_INITIAL_DELAY_SECONDS=30
SCHEDULER_INTERVAL_SECONDS=86400

# --- Job locking / caching ---
JOB_LOCK_TTL_SECONDS=1800
CACHE_TTL_SECONDS=15

# --- Optional bootstrap ---
# If DB is empty, auto-fetch data on startup. Defaults to false in production.
AUTO_BOOTSTRAP_IF_EMPTY=true

# --- Menu scraper tuning ---
MENU_SCRAPE_CONCURRENCY=8
MENU_SCRAPE_TIMEOUT_SECONDS=20
MENU_SCRAPE_RETRIES=2
