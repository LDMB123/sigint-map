# ClaudeCodeProjects .gitignore
# Created: 2026-01-25

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# Build artifacts
build/
dist/
.svelte-kit/
*.tsbuildinfo
.vite/
.turbo/

# Environment
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# Testing
coverage/
.nyc_output/
*.lcov
coverage-final.json

# Temporary
*.tmp
*.temp
.cache/
tmp/
**/.tmp/
.tmp_dmb_server.*

# Logs
logs/
*.log
**/_logs/
**/firebase-debug.log

# WASM build artifacts (pkg/ contains generated files but keep for now)
# Uncomment if you want to exclude WASM pkg/ directories:
# **/wasm/*/pkg/

# Rust
**/target/
**/*.rs.bk
Cargo.lock

# Scraper outputs and caches (generated data - should not be in git)
**/output/*.json
**/cache/*.json
**/checkpoint*.json
checkpoint_*.json

# DMB Almanac Rust generated artifacts
projects/dmb-almanac/rust/static/data/
projects/dmb-almanac/rust/static/pkg/
projects/dmb-almanac/rust/data/raw/
projects/dmb-almanac/rust/data/cache/
projects/dmb-almanac/rust/data/embedding-input.json
projects/dmb-almanac/rust/data/scrape-summary.json
projects/dmb-almanac/rust/data/warnings.json
projects/dmb-almanac/rust/data/warnings-fixtures.json
projects/dmb-almanac/rust/data/warnings-summary.json

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/

# Database
*.sqlite
*.sqlite3
*.db
*.db-wal
*.db-shm
# Exception: Keep DMB Almanac database
!projects/dmb-almanac/app/data/dmb-almanac.db

# Backups (dated backups are archived, not active)
*_backup_*
*_backup.*
*.bak
*.backup

# SIGINT-MAP intermediates
*_new.*
*_combined.*
*_part*.*
*_pre_integration_backup.*
merge_parts.py
new-integrations.js
section44-web-apis.js

# OS
Thumbs.db
Desktop.ini

# Security - Never commit these
**/secrets.*
**/credentials.*
**/.env.production
*.key
*.pem
*.crt

# Claude infrastructure - local only
.claude/mcp.json
.claude/mcp.json.backup*
.claude/agents_backup_*
.claude/agents_backup_*/
.claude/stats-cache.json
.claude/security_warnings_state_*.json
.claude/validation/raw-results.json
**/.claude/settings.local.json

# Playwright test artifacts
**/test-results/.playwright-artifacts-*/
**/playwright-report/

# Coverage data
**/coverage/coverage-final.json

# Empty db files
**/data/.gitkeep

# Project-level git repositories (each project has its own .git/)
projects/*/.git/
projects/*/.gitignore
