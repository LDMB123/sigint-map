# Google APIs Configuration
# Copy this file to .env and fill in your API keys

# =============================================================================
# GOOGLE MAPS API
# =============================================================================
# Get your API key from: https://console.cloud.google.com/google/maps-apis/credentials
# Enable these APIs in your Google Cloud Console:
#   - Geocoding API
#   - Places API
#   - Directions API
#   - Distance Matrix API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# =============================================================================
# GOOGLE CUSTOM SEARCH API
# =============================================================================
# Get your API key from: https://console.cloud.google.com/apis/credentials
# Enable "Custom Search API" in your Google Cloud Console

GOOGLE_CUSTOM_SEARCH_API_KEY=your_custom_search_api_key_here

# Get your Search Engine ID from: https://programmablesearchengine.google.com/
# Create a new search engine and copy the "Search engine ID"
GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id_here
